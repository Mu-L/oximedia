[package]
name = "oximedia-simd"
version = "0.1.0"
edition = "2021"
authors = ["OxiMedia Contributors"]
license = "MIT OR Apache-2.0"
description = "Hand-written assembly SIMD kernels for OxiMedia video codec"
repository = "https://github.com/oximedia/oximedia"

[dependencies]

[build-dependencies]
cc = "1.0"

[dev-dependencies]
criterion = "0.5"

[[bench]]
name = "simd_benchmarks"
harness = false

[lints.rust]
unsafe_code = "allow"

[lints.clippy]
all = "warn"
pedantic = "warn"
too_many_arguments = "allow"

[features]
default = ["runtime-dispatch"]
runtime-dispatch = []
force-avx2 = []
force-avx512 = []
force-neon = []
