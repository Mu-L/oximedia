[package]
name = "oximedia-proxy"
version.workspace = true
edition.workspace = true
license.workspace = true
rust-version.workspace = true
description = "Proxy and offline editing workflow system for OxiMedia"

[lints]
workspace = true

[dependencies]
oximedia-core = { workspace = true }
oximedia-transcode = { workspace = true }
oximedia-edl = { workspace = true }
oximedia-timecode = { workspace = true }
oximedia-metadata = { workspace = true }
thiserror = { workspace = true }
tokio = { workspace = true }
serde = { workspace = true, features = ["derive"] }
tracing = { workspace = true }
rayon = { workspace = true }

[dev-dependencies]
tokio = { workspace = true, features = ["test-util"] }
